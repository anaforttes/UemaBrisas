generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMs
// ──────────────────────────────────────────────

enum UserStatus {
  Online
  Offline
}

enum ProfessionalType {
  Advogado
  Engenheiro
  Arquiteto
  Topografo      @map("Topógrafo")
  AssistenteSocial @map("Assistente Social")
  Geologo        @map("Geólogo")
  Cidadao        @map("Cidadão")
  Terceirizado
  Representante
  Outro
}

enum ProcessStatus {
  Inicial
  Iniciado
  Levantamento_Tecnico  @map("Levantamento Técnico")
  Em_Analise            @map("Em Análise")
  Analise_Juridica      @map("Análise Jurídica")
  Diligencia            @map("Diligência")
  Em_Edital             @map("Em Edital")
  Aprovado
  Concluido             @map("Concluído")
  Finalizado
  Arquivado
}

enum ProcessModality {
  REURB_S  @map("REURB-S")
  REURB_E  @map("REURB-E")
}

enum StepStatus {
  pendente
  em_andamento
  concluida
  bloqueada
  cancelada
}

enum DocumentStatus {
  Draft
  Review
  Approved
  Signed
}

enum SignatureStatus {
  pending
  signed
  rejected
}

enum AuditAction {
  login
  logout
  signup
  create
  update
  delete
  status_change
  export
  sign
}

// ──────────────────────────────────────────────
// MODELS
// ──────────────────────────────────────────────

model Role {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @unique @db.VarChar(50)
  description String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  userRoles   UserRole[]

  @@map("roles")
}

model User {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String            @db.VarChar(200)
  email            String            @unique @db.VarChar(255)
  passwordHash     String            @map("password_hash") @db.VarChar(255)
  avatarUrl        String?           @map("avatar_url")
  professionalType ProfessionalType? @map("professional_type")
  allowedSteps     Int[]             @default([]) @map("allowed_steps")
  status           UserStatus        @default(Offline)
  lastLoginAt      DateTime?         @map("last_login_at") @db.Timestamptz()
  quotaLimit       Int               @default(10000) @map("quota_limit")
  quotaUsed        Int               @default(0) @map("quota_used")
  quotaResetAt     DateTime?         @map("quota_reset_at") @db.Timestamptz()
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt        DateTime?         @map("deleted_at") @db.Timestamptz()

  userRoles          UserRole[]
  refreshTokens      RefreshToken[]
  technicianProcesses Process[] @relation("technician")
  legalProcesses     Process[] @relation("legal")
  documents          Document[]
  documentVersions   DocumentVersion[]
  documentSignatures DocumentSignature[]
  documentComments   DocumentComment[]
  processHistories   ProcessHistory[]
  processStepsOwned  ProcessStep[]
  auditLogs          AuditLog[]

  @@map("users")
}

model UserRole {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model AuditLog {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?     @map("user_id") @db.Uuid
  action    AuditAction
  entity    String      @db.VarChar(100)
  entityId  String?     @map("entity_id") @db.VarChar(100)
  details   Json?
  ipAddress String?     @map("ip_address") @db.VarChar(45)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Process {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  protocol        String          @unique @db.VarChar(20)
  title           String          @db.VarChar(300)
  applicant       String          @db.VarChar(300)
  location        String?
  modality        ProcessModality
  status          ProcessStatus   @default(Inicial)
  area            String?         @db.VarChar(50)
  progress        Int             @default(0) @db.SmallInt
  responsibleName String?         @map("responsible_name") @db.VarChar(200)
  technicianId    String?         @map("technician_id") @db.Uuid
  legalId         String?         @map("legal_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz()

  technician     User?            @relation("technician", fields: [technicianId], references: [id], onDelete: SetNull)
  legal          User?            @relation("legal", fields: [legalId], references: [id], onDelete: SetNull)
  documents      Document[]
  processHistory ProcessHistory[]
  steps          ProcessStep[]

  @@map("processes")
}

model ProcessStep {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  processId     String     @map("process_id") @db.Uuid
  stepNumber    Int        @map("step_number") @db.SmallInt
  name          String     @db.VarChar(200)
  axis          String?    @db.VarChar(50)
  status        StepStatus @default(pendente)
  responsibleId String?    @map("responsible_id") @db.Uuid
  notes         String?
  startedAt     DateTime?  @map("started_at") @db.Timestamptz()
  concludedAt   DateTime?  @map("concluded_at") @db.Timestamptz()
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  process     Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  responsible User?   @relation(fields: [responsibleId], references: [id], onDelete: SetNull)

  @@unique([processId, stepNumber])
  @@map("process_steps")
}

model ProcessHistory {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  processId   String         @map("process_id") @db.Uuid
  changedById String?        @map("changed_by_id") @db.Uuid
  fromStatus  ProcessStatus? @map("from_status")
  toStatus    ProcessStatus  @map("to_status")
  notes       String?
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@map("process_history")
}

model DocumentTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(300)
  type        String   @db.VarChar(100)
  version     String   @default("1.0") @db.VarChar(20)
  contentHtml String?  @map("content_html")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  documents Document[]

  @@map("document_templates")
}

model Document {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  processId         String?        @map("process_id") @db.Uuid
  templateId        String?        @map("template_id") @db.Uuid
  authorId          String?        @map("author_id") @db.Uuid
  title             String         @db.VarChar(500)
  content           String         @default("")
  status            DocumentStatus @default(Draft)
  currentVersion    Int            @default(1) @map("current_version")
  signatureProtocol String?        @map("signature_protocol") @db.VarChar(50)
  documentHash      String?        @map("document_hash") @db.VarChar(100)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt         DateTime?      @map("deleted_at") @db.Timestamptz()

  process    Process?          @relation(fields: [processId], references: [id], onDelete: Cascade)
  template   DocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  author     User?             @relation(fields: [authorId], references: [id], onDelete: SetNull)
  versions   DocumentVersion[]
  signatures DocumentSignature[]
  comments   DocumentComment[]

  @@map("documents")
}

model DocumentVersion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  version    Int
  content    String
  editedById String?  @map("edited_by_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  editedBy User?    @relation(fields: [editedById], references: [id], onDelete: SetNull)

  @@unique([documentId, version])
  @@map("document_versions")
}

model DocumentSignature {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId    String          @map("document_id") @db.Uuid
  signerId      String?         @map("signer_id") @db.Uuid
  signerName    String          @map("signer_name") @db.VarChar(200)
  signerRole    String          @map("signer_role") @db.VarChar(100)
  signerEmail   String          @map("signer_email") @db.VarChar(255)
  signOrder     Int             @map("sign_order") @db.SmallInt
  status        SignatureStatus @default(pending)
  signatureHash String?         @map("signature_hash") @db.VarChar(100)
  signedAt      DateTime?       @map("signed_at") @db.Timestamptz()
  ipAddress     String?         @map("ip_address") @db.Inet
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz()

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signer   User?    @relation(fields: [signerId], references: [id], onDelete: SetNull)

  @@map("document_signatures")
}

model DocumentComment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  authorId   String?  @map("author_id") @db.Uuid
  authorName String   @map("author_name") @db.VarChar(200)
  text       String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@map("document_comments")
}
